{
  "info": {
    "name": "AI Cyber Defender API",
    "description": "Complete Postman collection for the custom MVC Core PHP backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost/grad_project",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"name\": \"Admin User\",\r\n    \"username\": \"admin\",\r\n    \"password\": \"password123\"\r\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if(jsonData.data && jsonData.data.token) {",
                  "    pm.collectionVariables.set(\"token\", jsonData.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"username\": \"admin\",\r\n    \"password\": \"password123\"\r\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Get Current User (Me)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/me",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "me"]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "2. AI Integration",
      "item": [
        {
          "name": "Receive AI Attack Results",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"type\": \"SQL Injection\",\n    \"severity\": \"high\",\n    \"ip\": \"192.168.1.100\",\n    \"confidence\": 0.95,\n    \"explanation\": \"Detected unusual union select pattern indicating potential SQLi.\",\n    \"logs\": [\n        \"Attempted SELECT * FROM users\",\n        \"UNION applied on primary query\"\n    ],\n    \"timeline\": [\n        { \"timestamp\": \"2026-04-24 12:00:00\", \"description\": \"Connection opened from suspicious IP\" },\n        { \"timestamp\": \"2026-04-24 12:00:05\", \"description\": \"Malicious payload sent\" }\n    ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/ai/results",
              "host": ["{{base_url}}"],
              "path": ["api", "ai", "results"]
            }
          }
        }
      ]
    },
    {
      "name": "3. Attacks Module",
      "item": [
        {
          "name": "Get All Attacks (Paginated/Filtered)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/attacks?page=1&limit=10&severity=high",
              "host": ["{{base_url}}"],
              "path": ["api", "attacks"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "severity", "value": "high" }
              ]
            }
          }
        },
        {
          "name": "Get Recent Attacks",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/attacks/recent?limit=5",
              "host": ["{{base_url}}"],
              "path": ["api", "attacks", "recent"],
              "query": [
                { "key": "limit", "value": "5" }
              ]
            }
          }
        },
        {
          "name": "Get Attack by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/attacks/1",
              "host": ["{{base_url}}"],
              "path": ["api", "attacks", "1"]
            }
          }
        },
        {
          "name": "Update Attack Status",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"status\": \"resolved\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/attacks/1/status",
              "host": ["{{base_url}}"],
              "path": ["api", "attacks", "1", "status"]
            }
          }
        },
        {
          "name": "Delete Attack",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/attacks/1",
              "host": ["{{base_url}}"],
              "path": ["api", "attacks", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "4. Dashboard & Statistics",
      "item": [
        {
          "name": "Dashboard Stats",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/dashboard/stats",
              "host": ["{{base_url}}"],
              "path": ["api", "dashboard", "stats"]
            }
          }
        },
        {
          "name": "Dashboard Charts",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/dashboard/charts",
              "host": ["{{base_url}}"],
              "path": ["api", "dashboard", "charts"]
            }
          }
        },
        {
          "name": "Detailed Statistics",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/statistics",
              "host": ["{{base_url}}"],
              "path": ["api", "statistics"]
            }
          }
        }
      ]
    }
  ]
}
